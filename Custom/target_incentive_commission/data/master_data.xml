<odoo noupdate="1">
    <record id="category_sr_manager" model="incentive.employee.category">
        <field name="name">Sr. Managers &amp; Above</field>
        <field name="code">SR_MANAGER</field>
        <field name="sequence">10</field>
    </record>
    <record id="category_team" model="incentive.employee.category">
        <field name="name">Team</field>
        <field name="code">TEAM</field>
        <field name="sequence">20</field>
