        <field name="use_receipt_exchange">1</field>
        <field name="sequence">10</field>
    </record>
    <record id="segment_local_sales" model="incentive.segment">
        <field name="name">Local Sales &amp; Services</field>
        <field name="code">LOCAL_SALES</field>
        <field name="basis_type">profit_excl_gst</field>
        <field name="sequence">20</field>
    </record>
