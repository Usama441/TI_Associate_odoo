<odoo>
    <record id="view_incentive_target_list" model="ir.ui.view">
        <field name="name">incentive.target.line.list</field>
        <field name="model">incentive.target.line</field>
        <field name="arch" type="xml">
            <list>
                <field name="review_period_id"/>
                <field name="employee_id"/>
                <field name="category_id"/>
                <field name="segment_id"/>
                <field name="target_amount"/>
                <field name="achievement_amount"/>
                <field name="achievement_percent"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_incentive_target_form" model="ir.ui.view">
        <field name="name">incentive.target.line.form</field>
        <field name="model">incentive.target.line</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_confirm" string="Confirm" type="object" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_set_draft" string="Set to Draft" type="object" invisible="state == 'draft'"/>
                    <button name="action_cancel" string="Cancel" type="object" invisible="state == 'cancelled'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,cancelled"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="review_period_id"/>
                            <field name="employee_id"/>
                            <field name="category_id" readonly="1"/>
                            <field name="department_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="segment_id"/>
                            <field name="target_amount"/>
                            <field name="achievement_amount"/>
                            <field name="achievement_percent" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="measure_note"/>
                        <field name="is_manual"/>
                    </group>
                    <notebook>
                        <page string="Notes">
                            <field name="note"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_incentive_target_search" model="ir.ui.view">
        <field name="name">incentive.target.line.search</field>
        <field name="model">incentive.target.line</field>
        <field name="arch" type="xml">
            <search>
                <field name="employee_id"/>
                <field name="segment_id"/>
                <field name="review_period_id"/>
                <field name="category_id"/>
                <filter string="Confirmed" name="confirmed" domain="[('state','=','confirmed')]"/>
                <group>
                    <filter string="Period" name="group_period" context="{'group_by':'review_period_id'}"/>
                    <filter string="Employee" name="group_employee" context="{'group_by':'employee_id'}"/>
                    <filter string="Segment" name="group_segment" context="{'group_by':'segment_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_incentive_target" model="ir.actions.act_window">
        <field name="name">Targets &amp; Achievements</field>
        <field name="res_model">incentive.target.line</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_incentive_target_search"/>
    </record>

    <menuitem id="menu_incentive_targets" name="Targets &amp; Achievements" parent="menu_incentive_root" action="action_incentive_target" sequence="20" groups="target_incentive_commission.group_incentive_user"/>
</odoo>
