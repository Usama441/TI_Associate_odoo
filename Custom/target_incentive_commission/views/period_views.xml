<odoo>
    <record id="view_incentive_period_list" model="ir.ui.view">
        <field name="name">incentive.review.period.list</field>
        <field name="model">incentive.review.period</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="period_type"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <field name="state"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="view_incentive_period_form" model="ir.ui.view">
        <field name="name">incentive.review.period.form</field>
        <field name="model">incentive.review.period</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="state" widget="statusbar" statusbar_visible="draft,open,closed"/>
                </header>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="period_type"/>
                        <field name="company_id" groups="base.group_multi_company"/>
                    </group>
                    <group>
                        <field name="date_start"/>
                        <field name="date_end"/>
                        <field name="active"/>
                    </group>
                    <group>
                        <field name="note"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_incentive_period_search" model="ir.ui.view">
        <field name="name">incentive.review.period.search</field>
        <field name="model">incentive.review.period</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="period_type"/>
                <field name="state"/>
                <filter string="Quarterly" name="quarterly" domain="[('period_type','=','quarterly')]"/>
                <filter string="Semiannual" name="semiannual" domain="[('period_type','=','semiannual')]"/>
                <group>
                    <filter string="Type" name="group_type" context="{'group_by':'period_type'}"/>
                    <filter string="State" name="group_state" context="{'group_by':'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_incentive_period" model="ir.actions.act_window">
        <field name="name">Review / Settlement Periods</field>
        <field name="res_model">incentive.review.period</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_incentive_period_search"/>
    </record>

    <menuitem id="menu_incentive_periods" name="Periods" parent="menu_incentive_root" action="action_incentive_period" sequence="10" groups="target_incentive_commission.group_incentive_user"/>
</odoo>
