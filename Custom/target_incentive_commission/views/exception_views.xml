<odoo>
    <record id="view_incentive_exception_list" model="ir.ui.view">
        <field name="name">incentive.exception.request.list</field>
        <field name="model">incentive.exception.request</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="source_record_id"/>
                <field name="employee_id"/>
                <field name="segment_id"/>
                <field name="exception_type"/>
                <field name="requested_by"/>
                <field name="state"/>
                <field name="approved_by"/>
                <field name="approved_on"/>
            </list>
        </field>
    </record>

    <record id="view_incentive_exception_form" model="ir.ui.view">
        <field name="name">incentive.exception.request.form</field>
        <field name="model">incentive.exception.request</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_submit" string="Submit" type="object" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_approve" string="Approve" type="object" class="btn-primary" invisible="state not in ('submitted','draft')" groups="target_incentive_commission.group_incentive_manager"/>
                    <button name="action_reject" string="Reject" type="object" invisible="state not in ('submitted','draft')" groups="target_incentive_commission.group_incentive_manager"/>
                    <button name="action_cancel" string="Cancel" type="object" invisible="state in ('cancelled','approved','rejected')"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,submitted,approved,rejected,cancelled"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="source_record_id"/>
                            <field name="employee_id" readonly="1"/>
                            <field name="segment_id" readonly="1"/>
                            <field name="exception_type"/>
                        </group>
                        <group>
                            <field name="requested_by" readonly="1"/>
                            <field name="requested_override_amount"/>
                            <field name="approved_by" readonly="1"/>
                            <field name="approved_on" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="reason"/>
                        <field name="manager_note"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_incentive_exception" model="ir.actions.act_window">
        <field name="name">Exception Requests</field>
        <field name="res_model">incentive.exception.request</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_incentive_exceptions" name="Exceptions" parent="menu_incentive_root" action="action_incentive_exception" sequence="40" groups="target_incentive_commission.group_incentive_user"/>
</odoo>
