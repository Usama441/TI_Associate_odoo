<odoo>
    <record id="privilege_incentive_management" model="res.groups.privilege">
        <field name="name">Incentive Management</field>
        <field name="sequence">50</field>
        <field name="category_id" ref="base.module_category_human_resources"/>
    </record>

    <record id="group_incentive_user" model="res.groups">
        <field name="name">Incentive User</field>
        <field name="privilege_id" ref="target_incentive_commission.privilege_incentive_management"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_incentive_manager" model="res.groups">
        <field name="name">Incentive Manager</field>
        <field name="privilege_id" ref="target_incentive_commission.privilege_incentive_management"/>
        <field name="implied_ids" eval="[(4, ref('group_incentive_user'))]"/>
    </record>

    <record id="group_incentive_admin" model="res.groups">
        <field name="name">Incentive Admin</field>
        <field name="privilege_id" ref="target_incentive_commission.privilege_incentive_management"/>
        <field name="implied_ids" eval="[(4, ref('group_incentive_manager'))]"/>
        <field name="user_ids" eval="[(4, ref('base.user_admin'))]"/>
    </record>

    <record id="base.group_system" model="res.groups">
        <field name="implied_ids" eval="[(4, ref('target_incentive_commission.group_incentive_manager'))]"/>
    </record>
</odoo>
