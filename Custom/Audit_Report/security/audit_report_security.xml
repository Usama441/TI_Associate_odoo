<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="audit_report_document_active_company_rule" model="ir.rule">
            <field name="name">Audit Report Document Active Company</field>
            <field name="model_id" ref="model_audit_report_document"/>
            <field name="domain_force">[('company_id', 'in', user.company_ids.ids)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="audit_report_revision_active_company_rule" model="ir.rule">
            <field name="name">Audit Report Revision Active Company</field>
            <field name="model_id" ref="model_audit_report_revision"/>
            <field name="domain_force">[('company_id', 'in', user.company_ids.ids)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>

    </data>
</odoo>
