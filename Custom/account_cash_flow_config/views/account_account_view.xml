<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <record id="view_account_account_form_inherit_cash_flow" model="ir.ui.view">
        <field name="name">account.account.form.inherit.cash.flow</field>
        <field name="model">account.account</field>
        <field name="inherit_id" ref="account.view_account_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='account_type']" position="after">
                <field name="cash_flow_type"/>
            </xpath>
        </field>
    </record>
</odoo>