<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_users_form_custom_module_permissions" model="ir.ui.view">
            <field name="name">res.users.form.custom.module.permissions</field>
            <field name="model">res.users</field>
            <field name="inherit_id" ref="base.view_users_form"/>
            <field name="arch" type="xml">
                <xpath expr="//page[@name='access_rights']//field[@name='company_id']" position="after">
                    <field name="custom_module_group_ids"
                           widget="many2many_tags"
                           options="{'no_create': True, 'no_create_edit': True}"
                           invisible="share"/>
                    <field name="allow_debug_mode" invisible="share"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
