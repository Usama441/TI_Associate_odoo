                                            <col style="width: 14%;"/>
                                            <col style="width: 9%;"/>
                                            <col style="width: 11%;"/>
                                            <col style="width: 12%;"/>
                                            <col style="width: 6%;"/>
                                            <col style="width: 6%;"/>
                                            <col style="width: 8%;"/>
                                            <col style="width: 12%;"/>
                                        </colgroup>
