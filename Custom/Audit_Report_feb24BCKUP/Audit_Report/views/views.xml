<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Account Report Wizard Form View -->
        <record id="account_report_wizard_form" model="ir.ui.view">
            <field name="name">audit.report.form</field>
            <field name="model">audit.report</field>
            <field name="arch" type="xml">
                <form string="Account Report Wizard">
                    <notebook>
                        <page string="Report Settings">
                            <group>
                                <group string="Report Dates">
                                    <field name="date_start"/>
                                    <field name="date_end"/>
                                    <field name="balance_sheet_date_mode"/>
                                    <field name="prior_year_mode"/>
                                    <field name="prior_balance_sheet_date_mode"/>
                                    <field name="prior_date_start"
                                           invisible="prior_year_mode != 'manual'"
                                           required="prior_year_mode == 'manual'"/>
                                    <field name="prior_date_end"
                                           invisible="prior_year_mode != 'manual'"
                                           required="prior_year_mode == 'manual'"/>
                                    <field name="soce_prior_opening_label_date"
                                           invisible="prior_year_mode != 'manual' or prior_balance_sheet_date_mode != 'end_only'"/>
                                </group>
                                <group string="Report Options">
                                    <field name="report_type"/>
                                    <field name="audit_period_category"/>
                                    <field name="auditor_type"/>
                                    <field name="show_related_parties_note"/>
                                    <field name="show_shareholder_note"/>
                                    <field name="corporate_tax_liability_paid"/>
                                    <field name="show_ct_first_tax_year_line"/>
                                </group>
                                <group string="Emphasis of Matter">
                                    <field name="emphasis_change_period"/>
                                    <field name="emphasis_change_from_date"
                                           invisible="not emphasis_change_period"
                                           required="emphasis_change_period"/>
                                    <field name="emphasis_change_to_date"
                                           invisible="not emphasis_change_period"
                                           required="emphasis_change_period"/>
                                    <field name="emphasis_correction_error"/>
                                    <field name="emphasis_liquidation"/>
                                </group>
                                <group string="Additional Notes">
                                    <field name="additional_note_legal_status_change"/>
                                    <field name="emphasis_legal_change_date"
                                           invisible="not additional_note_legal_status_change"
                                           required="additional_note_legal_status_change"/>
                                    <field name="emphasis_legal_status_from"
                                           invisible="not additional_note_legal_status_change"
                                           required="additional_note_legal_status_change"/>
                                    <field name="emphasis_legal_status_to"
                                           invisible="not additional_note_legal_status_change"
                                           required="additional_note_legal_status_change"/>
                                    <field name="additional_note_no_active_bank_account"/>
                                    <field name="additional_note_business_bank_account_opened"/>
                                </group>
                                <group string="Previous Settings">
                                    <field name="use_previous_settings"/>
                                </group>
                            </group>
                        </page>
                        <page string="Layout Controls">
                            <group>
                                <group string="Paragraph Gap Controls">
                                    <field name="gap_report_of_directors"/>
                                    <field name="gap_independent_auditor_report"/>
                                    <field name="gap_notes_to_financial_statements"/>
                                </group>
                                <group string="Signature Break Lines (&lt;br&gt;)">
                                    <field name="signature_break_lines_report_of_directors"/>
                                    <field name="signature_break_lines_balance_sheet"/>
                                    <field name="signature_break_lines_profit_loss"/>
                                    <field name="signature_break_lines_changes_in_equity"/>
                                    <field name="signature_break_lines_cash_flows"/>
                                    <field name="signature_break_lines_notes"/>
                                </group>
                            </group>
                        </page>
                        <page string="Trial Balance Overrides">
                            <group>
                                <group string="Controls">
                                    <field name="tb_include_zero_accounts"/>
                                    <div style="margin: 0 0 8px 0; color: #6c757d;">
                                        Load trial balance lines, adjust overrides, then regenerate HTML/PDF. These overrides are report-only and never update ledger entries.
                                    </div>
                                    <div class="o_row" style="gap: 8px;">
                                        <button name="action_tb_load_lines" type="object" string="Load Lines" class="btn btn-secondary"/>
                                        <button name="action_tb_reload_lines" type="object" string="Reload Lines" class="btn btn-secondary"/>
                                        <button name="action_tb_reset_overrides" type="object" string="Reset Overrides" class="btn btn-secondary"/>
                                    </div>
                                </group>
                                <group string="Mismatch Warnings">
                                    <field name="tb_warning_current" readonly="1" invisible="not tb_warning_current"/>
                                    <field name="tb_diff_current" readonly="1"/>
                                    <field name="tb_warning_prior" readonly="1"
                                           invisible="(not tb_warning_prior) or audit_period_category in ('cessation_1y', 'normal_1y', 'dormant_1y')"/>
                                    <field name="tb_diff_prior" readonly="1"
                                           invisible="audit_period_category in ('cessation_1y', 'normal_1y', 'dormant_1y')"/>
                                </group>
                            </group>
                            <group string="Current Period Overrides">
                                <field name="tb_override_line_ids" domain="[('period_key', '=', 'current')]" nolabel="1">
                                    <list editable="bottom" create="0" delete="0">
                                        <field name="account_code" readonly="1"/>
                                        <field name="account_name" readonly="1"/>
                                        <field name="system_debit" readonly="1"/>
                                        <field name="system_credit" readonly="1"/>
                                        <field name="system_balance" readonly="1"/>
                                        <field name="override_debit"/>
                                        <field name="override_credit"/>
                                        <field name="override_balance"/>
                                        <field name="effective_debit" readonly="1"/>
                                        <field name="effective_credit" readonly="1"/>
                                        <field name="effective_balance" readonly="1"/>
                                        <field name="is_overridden" readonly="1"/>
                                    </list>
                                </field>
                            </group>
                            <group string="Prior Period Overrides"
                                   invisible="audit_period_category in ('cessation_1y', 'normal_1y', 'dormant_1y')">
                                <field name="tb_override_line_ids" domain="[('period_key', '=', 'prior')]" nolabel="1">
                                    <list editable="bottom" create="0" delete="0">
                                        <field name="account_code" readonly="1"/>
                                        <field name="account_name" readonly="1"/>
                                        <field name="system_debit" readonly="1"/>
                                        <field name="system_credit" readonly="1"/>
                                        <field name="system_balance" readonly="1"/>
                                        <field name="override_debit"/>
                                        <field name="override_credit"/>
                                        <field name="override_balance"/>
                                        <field name="effective_debit" readonly="1"/>
                                        <field name="effective_credit" readonly="1"/>
                                        <field name="effective_balance" readonly="1"/>
                                        <field name="is_overridden" readonly="1"/>
                                    </list>
                                </field>
                            </group>
                        </page>
                        <page string="Company Info">
                            <group>
                                <group string="Company and Free Zone Information">
                                    <field name="company_id" readonly="1"/>
                                    <field name="company_street" string="Address"/>
                                    <field name="company_city"/>
                                    <field name="company_free_zone"/>
                                    <field name="company_license_number"/>
                                    <field name="trade_license_activities"/>
                                    <field name="incorporation_date"/>
                                </group>
                                <group string="Tax Information">
                                    <field name="corporate_tax_registration_number"/>
                                    <field name="vat_registration_number"/>
                                    <field name="corporate_tax_start_date"/>
                                    <field name="corporate_tax_end_date"/>
                                </group>
                                <group string="Free Zone Regulations">
                                    <field name="implementing_regulations_freezone"/>
                                </group>
                            </group>
                        </page>
                        <page string="Shareholders">
                            <group col="1">
