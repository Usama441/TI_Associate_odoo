                                                <td style="padding: 8px 10px; border-bottom: 1px solid #eceff3;" class="text-end"><field name="number_of_shares_9" nolabel="1" class="w-100"/></td>
                                                <td style="padding: 8px 10px; border-bottom: 1px solid #eceff3;" class="text-end"><field name="share_value_9" nolabel="1" class="w-100"/></td>
                                                <td style="padding: 8px 10px; border-bottom: 1px solid #eceff3;" class="text-end"><field name="total_share_9" readonly="1" nolabel="1" class="w-100"/></td>
                                                <td style="padding: 8px 10px; border-bottom: 1px solid #eceff3;" class="text-center"><field name="owner_include_9" nolabel="1" readonly="not shareholder_9"/></td>
                                                <td style="padding: 8px 10px; border-bottom: 1px solid #eceff3;" class="text-center"><field name="director_include_9" nolabel="1" readonly="not shareholder_9"/></td>
                                                <td style="padding: 8px 10px; border-bottom: 1px solid #eceff3;" class="text-center"><field name="signature_include_9" nolabel="1" readonly="not shareholder_9"/></td>
                                                <td style="padding: 8px 10px; border-bottom: 1px solid #eceff3;"><field name="signature_role_9" nolabel="1" readonly="not signature_include_9"/></td>
                                            </tr>
                                            <tr>
                                                <td style="padding: 8px 10px;"><field name="shareholder_10" nolabel="1" class="w-100"/></td>
                                                <td style="padding: 8px 10px;"><field name="nationality_10" nolabel="1" class="w-100"/></td>
                                                <td style="padding: 8px 10px;" class="text-end"><field name="number_of_shares_10" nolabel="1" class="w-100"/></td>
                                                <td style="padding: 8px 10px;" class="text-end"><field name="share_value_10" nolabel="1" class="w-100"/></td>
                                                <td style="padding: 8px 10px;" class="text-end"><field name="total_share_10" readonly="1" nolabel="1" class="w-100"/></td>
                                                <td style="padding: 8px 10px;" class="text-center"><field name="owner_include_10" nolabel="1" readonly="not shareholder_10"/></td>
                                                <td style="padding: 8px 10px;" class="text-center"><field name="director_include_10" nolabel="1" readonly="not shareholder_10"/></td>
                                                <td style="padding: 8px 10px;" class="text-center"><field name="signature_include_10" nolabel="1" readonly="not shareholder_10"/></td>
                                                <td style="padding: 8px 10px;"><field name="signature_role_10" nolabel="1" readonly="not signature_include_10"/></td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </group>
                                <group string="Related parties">
                                    <field name="related_party_name"/>
                                    <field name="related_party_relationship"/>
                                    <field name="related_party_transaction"/>
                                    <field name="related_party_amount"/>
                                    <field name="related_party_amount_prior"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                    <footer>
                        <button name="action_print_account_report_lines" type="object" 
                                string="View (HTML)" class="btn btn-primary"/>
                        <button name="action_print_account_report_pdf" type="object"
                                string="View (PDF)" class="btn btn-secondary"/>
                        <button name="action_save_editable_report" type="object"
                                string="Save/Edit PDF" class="btn btn-secondary"/>
                        <button string="Cancel" class="btn btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <!-- Wizard Action -->
        <record id="audit_report_wizard_action" model="ir.actions.act_window">
            <field name="name">Account Report</field>
            <field name="res_model">audit.report</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>

        <!-- Menu Item under Accounting > Reporting -->
        <menuitem id="account_report_menu"
                  name="Audit Reports"
                  parent="account.menu_finance_reports"
                  sequence="100"/>

        <menuitem id="account_report_generate_menu"
                  name="Generate Audit Report"
                  parent="account_report_menu"
                  action="audit_report_wizard_action"
                  sequence="100"/>

        <record id="audit_report_print_wizard_form" model="ir.ui.view">
            <field name="name">audit.report.print.wizard.form</field>
            <field name="model">audit.report.print.wizard</field>
            <field name="arch" type="xml">
                <form string="Print Saved Revision">
                    <group>
                        <field name="company_id" readonly="1"/>
                        <field name="document_id"/>
                        <field name="revision_id"/>
                    </group>
                    <footer>
                        <button name="action_print_revision" type="object" string="Print PDF" class="btn btn-primary"/>
                        <button string="Cancel" class="btn btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="view_audit_report_document_search" model="ir.ui.view">
            <field name="name">audit.report.document.search</field>
            <field name="model">audit.report.document</field>
            <field name="arch" type="xml">
                <search string="Saved Audit Reports">
                    <field name="name"/>
                    <field name="company_id"/>
                    <field name="date_start"/>
                    <field name="date_end"/>
                    <field name="report_type"/>
                    <field name="audit_period_category"/>
                    <filter name="active_only" string="Active" domain="[('active', '=', True)]"/>
                </search>
            </field>
        </record>

        <record id="view_audit_report_document_tree" model="ir.ui.view">
            <field name="name">audit.report.document.tree</field>
            <field name="model">audit.report.document</field>
            <field name="arch" type="xml">
                <list string="Saved Audit Reports">
                    <field name="name"/>
                    <field name="company_id"/>
                    <field name="date_start"/>
                    <field name="date_end"/>
                    <field name="report_type"/>
                    <field name="audit_period_category"/>
                    <field name="revision_count"/>
                    <field name="current_revision_id"/>
                    <field name="active"/>
                </list>
            </field>
        </record>

        <record id="view_audit_report_document_form" model="ir.ui.view">
            <field name="name">audit.report.document.form</field>
            <field name="model">audit.report.document</field>
            <field name="arch" type="xml">
                <form string="Saved Audit Report">
                    <header>
                        <button name="action_open_current_preview" type="object" string="Preview Current Revision" class="btn btn-secondary"/>
                        <button name="action_open_print_wizard" type="object" string="Print Revision" class="btn btn-primary"/>
                        <button name="action_open_revisions" type="object" string="Open Revisions" class="btn btn-secondary"/>
                    </header>
                    <sheet>
                        <group>
                            <group string="Report">
                                <field name="name"/>
                                <field name="company_id"/>
                                <field name="date_start"/>
                                <field name="date_end"/>
                                <field name="report_type"/>
                                <field name="audit_period_category"/>
                            </group>
                            <group string="Current State">
                                <field name="current_revision_id"/>
                                <field name="revision_count" readonly="1"/>
                                <field name="active"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Revisions">
                                <field name="revision_ids" nolabel="1">
                                    <list>
                                        <field name="display_name"/>
                                        <field name="version_no"/>
                                        <field name="created_by_id"/>
                                        <field name="created_on"/>
                                        <field name="is_current"/>
                                        <field name="is_removed"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Wizard Snapshot">
                                <field name="source_wizard_json" nolabel="1" widget="text"/>
                            </page>
                            <page string="TB Overrides Snapshot">
                                <field name="tb_overrides_json" nolabel="1" widget="text"/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_audit_report_revision_search" model="ir.ui.view">
            <field name="name">audit.report.revision.search</field>
            <field name="model">audit.report.revision</field>
            <field name="arch" type="xml">
                <search string="Report Revisions">
                    <field name="document_id"/>
                    <field name="company_id"/>
                    <field name="version_no"/>
                    <field name="created_by_id"/>
                    <filter name="active_only" string="Not Removed" domain="[('is_removed', '=', False)]"/>
                    <filter name="removed_only" string="Removed" domain="[('is_removed', '=', True)]"/>
                </search>
            </field>
        </record>

        <record id="view_audit_report_revision_tree" model="ir.ui.view">
            <field name="name">audit.report.revision.tree</field>
            <field name="model">audit.report.revision</field>
            <field name="arch" type="xml">
                <list string="Report Revisions">
                    <field name="display_name"/>
                    <field name="document_id"/>
                    <field name="company_id"/>
                    <field name="version_no"/>
                    <field name="is_current"/>
                    <field name="is_removed"/>
                    <field name="created_by_id"/>
                    <field name="created_on"/>
                </list>
            </field>
        </record>

        <record id="view_audit_report_revision_form" model="ir.ui.view">
            <field name="name">audit.report.revision.form</field>
            <field name="model">audit.report.revision</field>
            <field name="arch" type="xml">
                <form string="Report Revision">
                    <header>
                        <button name="action_open_preview" type="object" string="Preview HTML" class="btn btn-secondary"/>
                        <button name="action_open_pdf" type="object" string="View PDF" class="btn btn-secondary"/>
                        <button name="action_open_structured_editor" type="object" string="Structured Editor" class="btn btn-primary"/>
                        <button name="action_open_freeform_editor" type="object" string="Freeform Editor" class="btn btn-secondary"/>
                        <button name="action_soft_remove" type="object" string="Remove" class="btn btn-secondary" invisible="is_removed"/>
                        <button name="action_restore" type="object" string="Restore" class="btn btn-secondary" invisible="not is_removed"/>
                    </header>
                    <sheet>
                        <group>
                            <group string="Revision">
                                <field name="display_name" readonly="1"/>
                                <field name="document_id"/>
                                <field name="company_id"/>
                                <field name="version_no" readonly="1"/>
                                <field name="parent_revision_id"/>
                                <field name="is_current" readonly="1"/>
                            </group>
                            <group string="Lifecycle">
                                <field name="is_removed"/>
                                <field name="removed_by_id" readonly="1"/>
                                <field name="removed_on" readonly="1"/>
                                <field name="created_by_id" readonly="1"/>
                                <field name="created_on" readonly="1"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Table Index">
                                <field name="table_index_json" nolabel="1" widget="text" readonly="1"/>
                            </page>
                            <page string="TB Overrides Snapshot">
                                <field name="tb_overrides_json" nolabel="1" widget="text" readonly="1"/>
                            </page>
                            <page string="HTML Source">
                                <group>
                                    <separator string="HTML source is intentionally hidden in this form for faster loading."/>
                                    <separator string="Use Freeform Editor to edit content or Preview HTML to inspect the rendered report."/>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="audit_report_document_action" model="ir.actions.act_window">
            <field name="name">Saved Audit Reports</field>
            <field name="res_model">audit.report.document</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_audit_report_document_search"/>
            <field name="context">{'search_default_active_only': 1}</field>
        </record>

        <record id="audit_report_revision_action" model="ir.actions.act_window">
            <field name="name">Audit Report Revisions</field>
            <field name="res_model">audit.report.revision</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_audit_report_revision_search"/>
            <field name="context">{'search_default_active_only': 1}</field>
        </record>

        <menuitem id="audit_report_saved_menu"
                  name="Saved Audit Reports"
                  parent="account_report_menu"
                  action="audit_report_document_action"
                  sequence="110"/>

        <menuitem id="audit_report_revision_menu"
                  name="Audit Report Revisions"
                  parent="account_report_menu"
                  action="audit_report_revision_action"
                  sequence="120"/>
    </data>
</odoo>
