<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_audit_report_form_lor_integration" model="ir.ui.view">
        <field name="name">audit.report.form.lor.integration</field>
        <field name="model">audit.report</field>
        <field name="inherit_id" ref="Audit_Report.account_report_wizard_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form/footer/button[@special='cancel']" position="before">
                <button name="action_open_lor_wizard"
                        type="object"
                        string="Generate LOR"
                        class="btn btn-secondary"/>
            </xpath>
        </field>
    </record>
</odoo>
