<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Settings View for VAT Threshold -->
    <record id="vat_threshold_config_view_form" model="ir.ui.view">
        <field name="name">vat.threshold.config.view.form</field>
        <field name="model">vat.threshold.config</field>
        <field name="arch" type="xml">
            <form string="VAT Threshold Settings" class="oe_form_configuration">
                <sheet>
                    <div class="oe_title">
                        <h1>VAT Threshold Settings</h1>
                    </div>
                    <group string="Daily Report Configuration">
                        <field name="daily_report_recipients" placeholder="admin@company.com, cfo@company.com"/>
                        <p class="text-muted" colspan="2">
                            Enter comma-separated email addresses. Daily report will be sent automatically at 7:05 AM 
                            if any company requires VAT registration or cancellation action.
                        </p>
                    </group>
                </sheet>
                <footer>
                    <button string="Save" type="object" name="execute" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Action to Open Settings -->
    <record id="action_vat_threshold_config" model="ir.actions.act_window">
        <field name="name">VAT Threshold Settings</field>
        <field name="res_model">vat.threshold.config</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="view_id" ref="vat_threshold_config_view_form"/>
        <field name="group_ids" eval="[(4, ref('base.group_system'))]"/>
    </record>

    <!-- Settings Menu Item - Top Level under Audit Reports -->
    <menuitem id="menu_vat_threshold_config" 
              name="VAT Threshold Settings" 
              parent="Audit_Report.account_report_menu" 
              action="action_vat_threshold_config" 
              sequence="135"
              groups="base.group_system"/>
</odoo>
