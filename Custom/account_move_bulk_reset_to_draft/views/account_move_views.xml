<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="action_bulk_reset_to_draft_account_move" model="ir.actions.server">
            <field name="name">Bulk Reset to Draft</field>
            <field name="model_id" ref="account.model_account_move"/>
            <field name="binding_model_id" ref="account.model_account_move"/>
            <field name="binding_view_types">list</field>
            <field name="state">code</field>
            <field name="sequence">85</field>
            <field name="group_ids" eval="[(6, 0, [ref('account.group_account_manager')])]"/>
            <field name="code">
action = env['account.move'].browse(env.context.get('active_ids', [])).action_bulk_reset_to_draft()
            </field>
        </record>

        <record id="action_bulk_reset_to_draft_and_delete_account_move" model="ir.actions.server">
            <field name="name">Bulk Reset to Draft and Delete</field>
            <field name="model_id" ref="account.model_account_move"/>
            <field name="binding_model_id" ref="account.model_account_move"/>
            <field name="binding_view_types">list</field>
            <field name="state">code</field>
            <field name="sequence">86</field>
            <field name="group_ids" eval="[(6, 0, [ref('account.group_account_manager')])]"/>
            <field name="code">
action = env['account.move'].browse(env.context.get('active_ids', [])).action_bulk_reset_to_draft_and_delete()
            </field>
        </record>

    </data>
</odoo>
